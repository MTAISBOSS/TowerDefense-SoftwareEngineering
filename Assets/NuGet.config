<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="runflare" value="https://mirror-nuget.runflare.com/v3/index.json" />
    <add key="ChabokMirror" value="https://mirror2.chabokan.net/nuget/v3/index.json" />
    <add key="Local" value="C:\Users\Admin\.nuget\packages" enableCredentialProvider="false" />
  </packageSources>
  <disabledPackageSources>
    <add key="nuget.org" value="true" />
    <add key="ChabokMirror" value="true" />
  </disabledPackageSources>
  <packageSourceCredentials />
  <activePackageSource>
    <add key="All" value="(Aggregate source)" />
  </activePackageSource>
  <config>
    <add key="packageInstallLocation" value="CustomWithinAssets" />
    <add key="repositoryPath" value="./Packages" />
    <add key="PackagesConfigDirectoryPath" value="." />
    <add key="slimRestore" value="true" />
    <add key="PreferNetStandardOverNetFramework" value="true" />
  </config>
</configuration>